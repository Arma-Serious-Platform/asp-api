generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model File {
  id             String           @id @default(uuid())
  bucket         String
  filename       String
  url            String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  User           User[]
  Squad          Squad[]
  Mission        Mission[]
  MissionVersion MissionVersion[]
  missionVersionScreenshots MissionVersionScreenshot[]
  specializationIcons Specialization[] @relation("SpecializationIcon")
}

model GamePlan {
  id              String            @id @default(uuid())
  gameId          String
  game            Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sideId          String
  side            Side              @relation(fields: [sideId], references: [id], onDelete: Cascade)
  planUrl         String?
  gameCommanderId String?
  gameCommander   User?             @relation("GamePlanCommander", fields: [gameCommanderId], references: [id], onDelete: SetNull)
  comments        GamePlanComment[]
  slots           GamePlanSlot[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([gameId, sideId])
}

model GamePlanComment {
  id         String            @id @default(uuid())
  gamePlanId String
  gamePlan   GamePlan          @relation(fields: [gamePlanId], references: [id], onDelete: Cascade)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  message    Json
  replyId    String?
  replyTo    GamePlanComment?  @relation("GamePlanCommentReplies", fields: [replyId], references: [id])
  replies    GamePlanComment[] @relation("GamePlanCommentReplies")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model GamePlanSlot {
  id             String   @id @default(uuid())
  gamePlanId     String
  gamePlan       GamePlan @relation(fields: [gamePlanId], references: [id], onDelete: Cascade)
  slotNumber     String
  name           String?
  weaponry       String?
  slotCount      Int?     
  assignedSquads Squad[]  @relation("AssignedGamePlanSlots")
  wantedSquads   Squad[]  @relation("WantedGamePlanSlots")
  comment        String?
  spawnPoint     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id                          String            @id @default(uuid())
  avatarId                    String?
  avatar                      File?             @relation(fields: [avatarId], references: [id])
  email                       String            @unique
  nickname                    String            @unique
  password                    String
  steamId                     String?           @unique
  GUID                        String?           @unique
  lastIp                      String?
  abilities                   SoldierAbility[]
  squadId                     String?
  activationToken             String?
  activationTokenExpiresAt    DateTime?
  status                      UserStatus        @default(ACTIVE)
  role                        UserRole          @default(USER)
  squadRole                   SquadRole         @default(MEMBER)
  isMissionReviewer           Boolean           @default(false)
  resetPasswordToken          String?
  resetPasswordTokenExpiresAt DateTime?
  avatarUrl                   String?
  bannedUntil                 DateTime?
  isEmailVerified             Boolean           @default(false)
  missions                    Mission[]
  missionComments             MissionComment[]
  side                        Side?
  gamePlansAsCommander        GamePlan[]        @relation("GamePlanCommander")
  gamePlanComments            GamePlanComment[]
  coauthoredMissions          Mission[]         @relation("MissionCoauthors")
  warnings                    UserWarning[]     @relation("UserWarnings")
  issuedWarnings              UserWarning[]     @relation("IssuedUserWarnings")
  removedWarnings             UserWarning[]     @relation("RemovedUserWarnings")
  punishments                 UserPunishment[]  @relation("UserPunishments")
  issuedPunishments           UserPunishment[]  @relation("IssuedUserPunishments")
  leadingSquad                Squad?            @relation("SquadLeader")
  squadInvites                SquadInvitation[]
  squadJoinRequests           SquadJoinRequest[]
  squad                       Squad?            @relation("SquadMembers", fields: [squadId], references: [id])
  specializations             Specialization[]  @relation("UserSpecializations")
  games                       Game[]
  telegramUrl                 String?
  discordUrl                  String?
  youtubeUrl                  String?
  twitchUrl                   String?
  tiktokUrl                   String?
  chats                       ChatUser[] @relation("ChatUsers")
  messages                    Message[] @relation("UserMessages")
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
}

model UserWarning {
  id                String           @id @default(uuid())
  userId            String
  user              User             @relation("UserWarnings", fields: [userId], references: [id], onDelete: Cascade)
  adminId           String?
  admin             User?            @relation("IssuedUserWarnings", fields: [adminId], references: [id], onDelete: SetNull)
  removedById       String?
  removedBy         User?            @relation("RemovedUserWarnings", fields: [removedById], references: [id], onDelete: SetNull)
  reason            String
  removeReason      String?
  removedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  punishmentEntries UserPunishment[]

  @@index([userId])
  @@index([adminId])
  @@index([removedById])
  @@index([removedAt])
}

model UserPunishment {
  id            String             @id @default(uuid())
  userId        String
  user          User               @relation("UserPunishments", fields: [userId], references: [id], onDelete: Cascade)
  adminId       String?
  admin         User?              @relation("IssuedUserPunishments", fields: [adminId], references: [id], onDelete: SetNull)
  warningId     String?
  warning       UserWarning?       @relation(fields: [warningId], references: [id], onDelete: SetNull)
  type          UserPunishmentType
  reason        String?
  bannedUntil   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId])
  @@index([adminId])
  @@index([warningId])
  @@index([type])
}

model SiteSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Specialization {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  iconId    String?
  icon      File?    @relation("SpecializationIcon", fields: [iconId], references: [id], onDelete: SetNull)
  users     User[]   @relation("UserSpecializations")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Squad {
  id          String            @id @default(uuid())
  name        String            @unique
  leaderId    String            @unique
  sideId      String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  activeCount Int               @default(0)
  description String?
  tag         String            @unique
  leader      User              @relation("SquadLeader", fields: [leaderId], references: [id])
  side        Side              @relation(fields: [sideId], references: [id])
  invites     SquadInvitation[]
  joinRequests SquadJoinRequest[]
  members     User[]            @relation("SquadMembers")
  logoId      String?
  logo        File?             @relation(fields: [logoId], references: [id])
  recruiting  Boolean           @default(true)
  telegramUrl String?
  discordUrl  String?
  youtubeUrl  String?
  twitchUrl   String?
  tiktokUrl   String?
  assignedGamePlanSlots GamePlanSlot[] @relation("AssignedGamePlanSlots")
  wantedGamePlanSlots   GamePlanSlot[] @relation("WantedGamePlanSlots")
}

model SquadInvitation {
  id        String            @id @default(uuid())
  userId    String
  squadId   String
  status    SquadInviteStatus @default(PENDING)
  squadRole SquadRole         @default(MEMBER)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  squad     Squad             @relation(fields: [squadId], references: [id])
  user      User              @relation(fields: [userId], references: [id])
}

model SquadJoinRequest {
  id        String            @id @default(uuid())
  userId    String
  squadId   String
  status    SquadInviteStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  squad     Squad             @relation(fields: [squadId], references: [id])
  user      User              @relation(fields: [userId], references: [id])
}

model Side {
  id               String   @id @default(uuid())
  name             String   @unique
  type             SideType @default(UNASSIGNED)
  leaderId         String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  serverId         String?
  leader           User?    @relation(fields: [leaderId], references: [id])
  server           Server?  @relation(fields: [serverId], references: [id])
  squads           Squad[]
  gamesAttackSide  Game[]   @relation("GameAttackSide")
  gamesDefenseSide Game[]   @relation("GameDefenseSide")
  gamePlans        GamePlan[]
}

model Server {
  id        String       @id @default(uuid())
  name      String       @unique
  status    ServerStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  ip        String       @default("127.0.0.1")
  port      Int          @default(2302)
  sides     Side[]
}

model MissionWeaponry {
  id               String          @id @default(uuid())
  name             String
  description      String?
  count            Int
  type             MissionGameSide
  missionVersion   MissionVersion  @relation("MissionVersionWeaponry", fields: [missionVersionId], references: [id])
  missionVersionId String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model MissionVersion {
  id                 String            @id @default(uuid())
  version            String
  missionId          String
  mission            Mission           @relation(fields: [missionId], references: [id])
  status             MissionStatus     @default(PENDING_APPROVAL)
  attackSideType     MissionGameSide
  defenseSideType    MissionGameSide
  attackSideSlots    Int
  defenseSideSlots   Int
  missionAttackSlots Json?
  missionDefenceSlots Json?
  attackSideName     String
  defenseSideName    String
  weaponry           MissionWeaponry[] @relation("MissionVersionWeaponry")
  changesDescription String?
  games              Game[]
  rating             Int?
  fileId             String
  file               File              @relation(fields: [fileId], references: [id])
  uniformScreenshots MissionVersionScreenshot[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model MissionVersionScreenshot {
  id               String                       @id @default(uuid())
  missionVersionId String
  missionVersion   MissionVersion               @relation(fields: [missionVersionId], references: [id], onDelete: Cascade)
  fileId           String
  file             File                         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  side             MissionGameSide
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([missionVersionId, side])
}

model MissionComment {
  id        String          @id @default(uuid())
  missionId String
  mission   Mission         @relation(fields: [missionId], references: [id])
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  message   Json
  replyId   String?
  replyTo   MissionComment? @relation("CommentReplies", fields: [replyId], references: [id])
  replies   MissionComment[] @relation("CommentReplies")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Island {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  missions  Mission[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum MissionType {
  SG
  mini
}

model Mission {
  id              String           @id @default(uuid())
  name            String
  description     String
  missionType     MissionType @default(SG)
  authorId        String?
  author          User?            @relation(fields: [authorId], references: [id])
  coauthors       User[]           @relation("MissionCoauthors")
  missionVersions MissionVersion[]
  imageId         String?
  image           File?            @relation(fields: [imageId], references: [id])
  comments        MissionComment[]
  islandId        String?
  island          Island?          @relation(fields: [islandId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  games           Game[]
}

model Game {
  id            String   @id @default(uuid())
  date          DateTime
  weekendId     String
  weekend       Weekend  @relation(fields: [weekendId], references: [id])
  mission       Mission  @relation(fields: [missionId], references: [id])
  missionId     String
  missionVersion MissionVersion @relation(fields: [missionVersionId], references: [id])
  missionVersionId String
  adminId       String?
  admin         User?     @relation(fields: [adminId], references: [id])
  attackSideId  String
  attackSide    Side     @relation("GameAttackSide", fields: [attackSideId], references: [id])
  defenseSideId String
  defenseSide   Side     @relation("GameDefenseSide", fields: [defenseSideId], references: [id])
  position      Int @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  gamePlans     GamePlan[]
}

model Weekend {
  id          String   @id @default(uuid())
  name        String
  description String?
  games       Game[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chat {
  id        String     @id @default(uuid())
  name      String?
  type      ChatType   @default(DIRECT)
  users     ChatUser[]
  messages  Message[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model ChatUser {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("ChatUsers", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())
  leftAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chatId, userId])
}

model Message {
  id            String   @id @default(uuid())
  content       Json
  quoteMessageId String?
  quoteMessage  Message? @relation("MessageQuotes", fields: [quoteMessageId], references: [id])
  quotedMessages Message[] @relation("MessageQuotes")
  userId        String
  user          User     @relation("UserMessages", fields: [userId], references: [id])
  chatId        String
  chat          Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  editedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([chatId, createdAt])
}

enum ChatType {
  DIRECT
  GROUP
}

enum ServerStatus {
  ACTIVE
  INACTIVE
}

enum MissionStatus {
  APPROVED
  PENDING_APPROVAL
  CHANGES_REQUESTED
}

enum SideType {
  BLUE
  RED
  UNASSIGNED
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum UserRole {
  OWNER
  SERVER_ADMIN
  TECH_ADMIN
  UVK
  GAME_ADMIN
  MINI_ADMIN
  USER
}

enum UserPunishmentType {
  WARNING
  WARNING_REMOVED
  TEMP_BAN
  PERMANENT_BAN
  UNBAN
}

enum SoldierAbility {
  COMMANDER
  MEDIC
  SNIPER
  ANTI_TANK
  ANTI_AIR
  HELI_PILOT
  JET_PILOT
  TANK_CREW
  VEHICLE_CREW
}

enum SquadInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  LEAVED
}

enum MissionGameSide {
  BLUE
  RED
  GREEN
}

enum SquadRole {
  MEMBER
  HQ
  SUBLEADER
  RECRUIT
}